{
  "name": "local-plans-reps-analysis-poc",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.21.0"
  },
  "scripts": {
    "check-types": "npx tsc",
    "commitlint": "commitlint --from=$(git rev-parse $(git cherry origin/main | head -n 1 | cut -c 3-)^1)",
    "db-migrate-dev": "npm run migrate-dev --workspace @pins/local-plans-reps-analysis-poc-database",
    "db-migrate-prod": "npm run migrate-prod --workspace @pins/local-plans-reps-analysis-poc-database",
    "db-generate": "npm run generate --workspace @pins/local-plans-reps-analysis-poc-database",
    "db-seed": "npm run seed --workspace @pins/local-plans-reps-analysis-poc-database",
    "db-seed-prod": "npm run seed:prod --workspace @pins/local-plans-reps-analysis-poc-database",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "lint": "npx eslint .",
    "prepare": "node .husky/install.mjs",
    "test": "node --test",
    "test-coverage": "node --test --experimental-test-coverage"
  },
  "dependencies": {
    "@azure/functions": "^4.16.1",
    "@azure/identity": "^4.13.1",
    "@azure/msal-node": "^5.2.5",
    "@planning-inspectorate/dynamic-forms": "^3.10.8",
    "@prisma/adapter-mssql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "accessible-autocomplete": "^3.0.1",
    "body-parser": "^2.3.0",
    "connect-redis": "^9.0.0",
    "csv-parser": "^3.2.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "govuk-frontend": "^6.2.0",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "redis": "^6.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^26.0.0",
    "@types/nunjucks": "^3.2.6",
    "cookie-parser": "^1.4.7",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.4",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.8.0",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{js,ts,json,md,prisma,yml,yaml,scss}": [
      "prettier --write"
    ]
  }
}
